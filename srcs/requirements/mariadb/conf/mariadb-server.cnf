[mysqld]
# Basic Configuration
user			= mysql
port			= 3306
basedir			= /usr
datadir			= /var/lib/mysql
socket			= /run/mysqld/mysqld.sock

# Network Settings
# Bind to 0.0.0.0 to allow incoming connections from the Docker bridge network
bind-address	= 0.0.0.0
skip-networking	= false

# Performance Tuning (Optimized for small Virtual Machines)
query_cache_size		= 32M
innodb_buffer_pool_size	= 128M
